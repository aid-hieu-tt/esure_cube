# Cube.js API Configuration
# ⚠️ Đặt trên platform HOẶC trong file .env — không cần sửa source code
VITE_CUBE_API_URL="http://localhost:4000/cubejs-api/v1"
VITE_CUBE_TOKEN="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpYXQiOjE3MTI3MDAwMDB9.placeholder"

# GEMINI_API_KEY: Required for Gemini AI API calls (optional).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"
